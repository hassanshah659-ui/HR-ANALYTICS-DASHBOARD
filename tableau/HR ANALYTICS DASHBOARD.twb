      </column>
      <column caption='Attrition Rate' datatype='real' name='[Calculation_1728485915660293]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Attrition] = &quot;Yes&quot; THEN 1 ELSE 0 END) &#13;&#10;/ COUNT([EmployeeNumber])' />
      </column>
      <column caption='Color' datatype='string' name='[Calculation_1728485924675590]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Department] = &quot;Sales&quot; THEN &quot;High Attrition&quot; ELSE &quot;Other&quot; END' />
