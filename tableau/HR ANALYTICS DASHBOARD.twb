      <column aggregation='Sum' caption='Risk Score' datatype='integer' name='[Calculation_0837061747089408]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [JobSatisfaction] &lt;= 2 THEN 1 ELSE 0 END +&#13;&#10;IF [EnvironmentSatisfaction] &lt;= 2 THEN 1 ELSE 0 END +&#13;&#10;IF [WorkLifeBalance] &lt;= 2 THEN 1 ELSE 0 END +&#13;&#10;IF [YearsAtCompany] &lt; 3 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Risk Score (RS)' datatype='real' name='[Calculation_0837061769199617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Normalize factors (0 to 1 scale)&#13;&#10;&#13;&#10;(&#13;&#10;    (5 - [JobSatisfaction]) / 4&#13;&#10;    +&#13;&#10;    (5 - [WorkLifeBalance]) / 4&#13;&#10;    +&#13;&#10;    IF [YearsAtCompany] &lt;= 3 THEN 1&#13;&#10;       ELSEIF [YearsAtCompany] &lt;= 7 THEN 0.5&#13;&#10;       ELSE 0.2&#13;&#10;    END&#13;&#10;    +&#13;&#10;    IF [OverTime] = &quot;Yes&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/ 4 * 100' />
      </column>
      <column caption='Remaining' datatype='real' name='[Calculation_0905229978447872]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='4 - AVG([JobInvolvement])' />
      </column>
      <column caption='Jitter' datatype='real' name='[Calculation_0905229984280577]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(RANDOM() - 0.5) * 0.2' />
      </column>
      <column caption='min(1)' datatype='integer' name='[Calculation_1139925281480704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Total Employees ' datatype='integer' name='[Calculation_1139925290328067]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([EmployeeNumber])' />
      </column>
      <column caption='At Risk Employees' datatype='integer' name='[Calculation_1139925290422276]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0837061747089408] &gt;= 2 THEN 1 END' />
      </column>
      <column caption='High Risk Employees' datatype='integer' name='[Calculation_1139925290483717]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0837061747089408] &gt;= 3 THEN 1 END' />
      </column>
      <column caption='Employee Left' datatype='integer' name='[Calculation_1139925290598406]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Attrition] = &quot;Yes&quot; THEN 1 END' />
      </column>
      <column caption='Job Satisfaction Category' datatype='string' name='[Calculation_1139925301485576]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [JobSatisfaction] = 1 THEN &quot;Low&quot;&#13;&#10;ELSEIF [JobSatisfaction] = 2 THEN &quot;Medium&quot;&#13;&#10;ELSEIF [JobSatisfaction] = 3 THEN &quot;High&quot;&#13;&#10;ELSE &quot;Very High&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Hired' datatype='integer' name='[Calculation_1728485911617536]' role='measure' type='quantitative'>
