    <worksheet name='Risk Score'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontname='Trebuchet MS' fontsize='10'> RISK SCORE</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='HR-Employee-Attrition' name='federated.0s8c9281ltx1es1c6ts6908w276t' />
          </datasources>
          <datasource-dependencies datasource='federated.0s8c9281ltx1es1c6ts6908w276t'>
            <column datatype='string' name='[Attrition]' role='dimension' type='nominal' />
            <column caption='Business Travel' datatype='string' name='[BusinessTravel]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Travel_Frequently&quot;' value='Travel Frequently' />
                <alias key='&quot;Travel_Rarely&quot;' value='Travel Rarely' />
              </aliases>
            </column>
            <column caption='Risk Score (RS)' datatype='real' name='[Calculation_0837061769199617]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Normalize factors (0 to 1 scale)&#13;&#10;&#13;&#10;(&#13;&#10;    (5 - [JobSatisfaction]) / 4&#13;&#10;    +&#13;&#10;    (5 - [WorkLifeBalance]) / 4&#13;&#10;    +&#13;&#10;    IF [YearsAtCompany] &lt;= 3 THEN 1&#13;&#10;       ELSEIF [YearsAtCompany] &lt;= 7 THEN 0.5&#13;&#10;       ELSE 0.2&#13;&#10;    END&#13;&#10;    +&#13;&#10;    IF [OverTime] = &quot;Yes&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/ 4 * 100' />
            </column>
            <column datatype='string' name='[Department]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Human Resources&quot;' value='HR' />
              </aliases>
            </column>
            <column caption='Education Field' datatype='string' name='[EducationField]' role='dimension' type='nominal' />
            <column datatype='string' name='[Gender]' role='dimension' type='nominal' />
            <column caption='Job Role' datatype='string' name='[JobRole]' role='dimension' type='nominal' />
            <column caption='Job Satisfaction' datatype='integer' name='[JobSatisfaction]' role='measure' type='quantitative' />
            <column caption='Over Time' datatype='string' name='[OverTime]' role='dimension' type='nominal' />
            <column caption='Work Life Balance' datatype='integer' name='[WorkLifeBalance]' role='measure' type='quantitative' />
            <column caption='Years At Company' datatype='integer' name='[YearsAtCompany]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0837061769199617]' derivation='Avg' name='[avg:Calculation_0837061769199617:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Attrition]' derivation='None' name='[none:Attrition:nk]' pivot='key' type='nominal' />
            <column-instance column='[BusinessTravel]' derivation='None' name='[none:BusinessTravel:nk]' pivot='key' type='nominal' />
            <column-instance column='[Department]' derivation='None' name='[none:Department:nk]' pivot='key' type='nominal' />
            <column-instance column='[EducationField]' derivation='None' name='[none:EducationField:nk]' pivot='key' type='nominal' />
            <column-instance column='[Gender]' derivation='None' name='[none:Gender:nk]' pivot='key' type='nominal' />
            <column-instance column='[JobRole]' derivation='None' name='[none:JobRole:nk]' pivot='key' type='nominal' />
            <column-instance column='[OverTime]' derivation='None' name='[none:OverTime:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <slices>
