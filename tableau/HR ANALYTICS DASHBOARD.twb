            <column-instance column='[Calculation_1139925290422276]' derivation='Sum' name='[sum:Calculation_1139925290422276:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1139925290483717]' derivation='Sum' name='[sum:Calculation_1139925290483717:qk]' pivot='key' type='quantitative' />
            <column-instance column='[EmployeeCount]' derivation='Sum' name='[sum:EmployeeCount:qk]' pivot='key' type='quantitative' />
