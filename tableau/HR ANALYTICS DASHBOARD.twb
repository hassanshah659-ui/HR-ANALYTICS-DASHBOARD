      <column caption='Highest Max Age' datatype='string' name='[Calculation_1728485928226824]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_1728485926637575]) = WINDOW_MAX(AVG([Calculation_1728485926637575]))&#13;&#10;THEN &quot;Highest&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END'>
